# Normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly mark as text (ensure LF)
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.txt text eol=lf

# Binary files (don't touch)
*.db binary
*.png binary
*.jpg binary
*.gif binary
